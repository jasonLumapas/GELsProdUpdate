        <AutoSuggestBox x:Name="ProductsAutoSuggestBox"
            Width="600"
            PlaceholderText="Search product..."
            TextChanged="ProductsAutoSuggestBox_TextChanged"
            SuggestionChosen="ProductsAutoSuggestBox_SuggestionChosen"
            QuerySubmitted="ProductsAutoSuggestBox_QuerySubmitted"/>

        <AutoSuggestBox x:Name="SuppliersAutoSuggestBox"
             Width="600"
             PlaceholderText="Search suppliers..."
             TextChanged="SuppliersAutoSuggestBox_TextChanged"
             SuggestionChosen="SuppliersAutoSuggestBox_SuggestionChosen"
             QuerySubmitted="SuppliersAutoSuggestBox_QuerySubmitted"/>   
        
        <StackPanel Margin="20" Orientation="Horizontal" VerticalAlignment="Center" Spacing="10">
            <TextBlock Text="Widrawal Price:" VerticalAlignment="Center"/>
            <TextBox x:Name="WidrawalTextBox" BeforeTextChanging="DecimalTextBox_BeforeTextChanging"
            Width="200" />
        </StackPanel>
        <StackPanel Margin="20" Orientation="Horizontal" VerticalAlignment="Center" Spacing="10">
            <TextBlock Text="Retail Price:" VerticalAlignment="Center"/>
            <TextBox x:Name="RetailTextBox" BeforeTextChanging="DecimalTextBox_BeforeTextChanging"
                     Width="200"/>
        </StackPanel>
        <StackPanel Margin="20" Orientation="Horizontal" VerticalAlignment="Center" Spacing="10">
            <TextBlock Text="Number of Pieces per box:" VerticalAlignment="Center"/>
            <TextBox x:Name="PiecesPerBoxTextBox" BeforeTextChanging="NumberOnlyTextBox_BeforeTextChanging"
                     Width="200"/>
        </StackPanel>
        <Button x:Name="ApplyButton" Click="ApplyButton_Click">Apply</Button>
    </StackPanel>

</Window>
